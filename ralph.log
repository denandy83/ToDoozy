        "content": "import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest'\nimport { renderHook, act } from '@testing-library/react'\nimport { useCalendar, toYMD } from './useCalendar'\n\ndescribe('toYMD', () => {\n  it('formats a date as YYYY-MM-DD', () => {\n    const d = new Date(2026, 2, 15) // March 15, 2026\n    expect(toYMD(d)).toBe('2026-03-15')\n  })\n\n  it('zero-pads single-digit months and days', () => {\n    const d = new Date(2026, 0, 5) // Jan 5, 2026\n    expect(toYMD(d)).toBe('2026-01-05')\n  })\n})\n\ndescribe('useCalendar', () => {\n  beforeEach(() => {\n    vi.useFakeTimers()\n    vi.setSystemTime(new Date(2026, 2, 15)) // March 15, 2026 (Sunday)\n  })\n\n  afterEach(() => {\n    vi.useRealTimers()\n  })\n\n  describe('month layout', () => {\n    it('returns days for the full month grid including padding days', () => {\n      const { result } = renderHook(() => useCalendar('month'))\n      // March 2026 starts on Sunday. Grid starts from previous Monday.\n      // Should have at least 28 days (for March) plus padding\n      expect(result.current.days.length).toBeGreaterThanOrEqual(28)\n      // Every row is 7 days, so total should be divisible by 7\n      expect(result.current.days.length % 7).toBe(0)\n    })\n\n    it('marks today correctly', () => {\n      const { result } = renderHook(() => useCalendar('month'))\n      const todayDay = result.current.days.find((d) => d.isToday)\n      expect(todayDay).toBeDefined()\n      expect(todayDay!.date).toBe('2026-03-15')\n    })\n\n    it('marks days outside current month', () => {\n      const { result } = renderHook(() => useCalendar('month'))\n      // First day should be a padding day (from February) since March 1, 2026 is a Sunday\n      // Grid starts on Monday, so first day is Feb 23\n      const firstDay = result.current.days[0]\n      expect(firstDay.isCurrentMonth).toBe(false)\n    })\n\n    it('navigates to next month', () => {\n      const { result } = renderHook(() => useCalendar('month'))\n      expect(result.current.title).toContain('March')\n\n      act(() => {\n        result.current.goNext()\n      })\n\n      expect(result.current.title).toContain('April')\n    })\n\n    it('navigates to previous month', () => {\n      const { result } = renderHook(() => useCalendar('month'))\n      expect(result.current.title).toContain('March')\n\n      act(() => {\n        result.current.goPrev()\n      })\n\n      expect(result.current.title).toContain('February')\n    })\n\n    it('goToday resets to current month', () => {\n      const { result } = renderHook(() => useCalendar('month'))\n\n      act(() => {\n        result.current.goNext()\n        result.current.goNext()\n      })\n\n      expect(result.current.title).toContain('May')\n\n      act(() => {\n        result.current.goToday()\n      })\n\n      expect(result.current.title).toContain('March')\n    })\n\n    it('title includes year', () => {\n      const { result } = renderHook(() => useCalendar('month'))\n      expect(result.current.title).toBe('March 2026')\n    })\n  })\n\n  describe('week layout', () => {\n    it('returns exactly 7 days', () => {\n      const { result } = renderHook(() => useCalendar('week'))\n      expect(result.current.days).toHaveLength(7)\n    })\n\n    it('starts on Monday', () => {\n      const { result } = renderHook(() => useCalendar('week'))\n      // March 15, 2026 is a Sunday, so the week starts on March 9 (Monday)\n      expect(result.current.days[0].date).toBe('2026-03-09')\n    })\n\n    it('ends on Sunday', () => {\n      const { result } = renderHook(() => useCalendar('week'))\n      expect(result.current.days[6].date).toBe('2026-03-15')\n    })\n\n    it('navigates to next week', () => {\n      const { result } = renderHook(() => useCalendar('week'))\n      const firstDate = result.current.days[0].date\n\n      act(() => {\n        result.current.goNext()\n      })\n\n      const newFirstDate = result.current.days[0].date\n      // Should be 7 days later\n      const diff = new Date(newFirstDate).getTime() - new Date(firstDate).getTime()\n      expect(diff).toBe(7 * 24 * 60 * 60 * 1000)\n    })\n\n    it('navigates to previous week', () => {\n      const { result } = renderHook(() => useCalendar('week'))\n      const firstDate = result.current.days[0].date\n\n      act(() => {\n        result.current.goPrev()\n      })\n\n      const newFirstDate = result.current.days[0].date\n      const diff = new Date(firstDate).getTime() - new Date(newFirstDate).getTime()\n      expect(diff).toBe(7 * 24 * 60 * 60 * 1000)\n    })\n\n    it('title shows date range', () => {\n      const { result } = renderHook(() => useCalendar('week'))\n      // Week of March 9-15, same month\n      expect(result.current.title).toContain('9')\n      expect(result.current.title).toContain('15')\n      expect(result.current.title).toContain('Mar')\n    })\n  })\n})\n"
