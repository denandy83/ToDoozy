        "old_string": "app.whenReady().then(() => {\n  electronApp.setAppUserModelId('com.todoozy')\n\n  initDatabase()\n  registerIpcHandlers()\n\n  app.on('browser-window-created', (_, window) => {\n    optimizer.watchWindowShortcuts(window)\n  })\n\n  createWindow()\n  createTray()\n  loadAndRegisterShortcut()\n  loadAndRegisterAppToggleShortcut()\n  startNotificationChecker()",
        "new_string": "// Register todoozy:// protocol for deep links (invite flow)\nif (process.defaultApp) {\n  if (process.argv.length >= 2) {\n    app.setAsDefaultProtocolClient('todoozy', process.execPath, [process.argv[1]])\n  }\n} else {\n  app.setAsDefaultProtocolClient('todoozy')\n}\n\n// Handle deep link on macOS (app already running)\napp.on('open-url', (event, url) => {\n  event.preventDefault()\n  handleDeepLink(url)\n})\n\nfunction handleDeepLink(url: string): void {\n  // Parse todoozy://invite/{token}\n  const match = url.match(/^todoozy:\\/\\/invite\\/([a-f0-9-]+)$/i)\n  if (match) {\n    const token = match[1]\n    // Send to renderer for processing\n    const win = mainWindow ?? BrowserWindow.getAllWindows()[0]\n    if (win && !win.isDestroyed()) {\n      win.show()\n      win.focus()\n      win.webContents.send('invite:received', token)\n    } else {\n      // App not ready yet — store for later\n      pendingInviteToken = token\n    }\n  }\n}\n\nlet pendingInviteToken: string | null = null\n\napp.whenReady().then(() => {\n  electronApp.setAppUserModelId('com.todoozy')\n\n  initDatabase()\n  registerIpcHandlers()\n\n  app.on('browser-window-created', (_, window) => {\n    optimizer.watchWindowShortcuts(window)\n  })\n\n  createWindow()\n  createTray()\n  loadAndRegisterShortcut()\n  loadAndRegisterAppToggleShortcut()\n  startNotificationChecker()\n\n  // Handle deep link from cold start (macOS: second-instance doesn't fire, use open-url)\n  // On Windows/Linux, check process.argv for the deep link URL\n  const deepLinkUrl = process.argv.find((arg) => arg.startsWith('todoozy://'))\n  if (deepLinkUrl) {\n    // Delay to let window initialize\n    setTimeout(() => handleDeepLink(deepLinkUrl), 1000)\n  }\n\n  // Send pending invite token if app was launched via deep link\n  if (pendingInviteToken && mainWindow) {\n    mainWindow.webContents.once('did-finish-load', () => {\n      if (pendingInviteToken) {\n        mainWindow?.webContents.send('invite:received', pendingInviteToken)\n        pendingInviteToken = null\n      }\n    })\n  }"
