{
  "model": "claude-opus-4-6",
  "id": "msg_01Lfb7RrYDiMM2aNVR915zeC",
  "type": "message",
  "role": "assistant",
  "content": [
    {
      "type": "tool_use",
      "id": "toolu_01K8u2cMByNmhjgyWm3t9DuF",
      "name": "mcp__supabase__apply_migration",
      "input": {
        "name": "update_quick_add_task_ios_default",
        "query": "CREATE OR REPLACE FUNCTION quick_add_task(p_api_key text, p_title text)\nRETURNS TABLE(title text, project_name text) AS $$\nDECLARE\n  v_user_id uuid;\n  v_project_id uuid;\n  v_project_name text;\n  v_status_id uuid;\n  v_task_id uuid;\n  v_now timestamptz := now();\n  v_order_index integer;\n  v_ios_default text;\nBEGIN\n  -- Validate API key and find user\n  SELECT us.user_id INTO v_user_id\n  FROM user_settings us\n  WHERE us.key = 'api_key' AND us.value = p_api_key::text;\n\n  IF v_user_id IS NULL THEN\n    RAISE EXCEPTION 'Invalid API key';\n  END IF;\n\n  -- Check iOS Shortcut default first\n  SELECT us.value INTO v_ios_default\n  FROM user_settings us\n  WHERE us.user_id = v_user_id AND us.key = 'ios_shortcut_default_project';\n\n  IF v_ios_default IS NOT NULL AND v_ios_default != 'follow_telegram' THEN\n    SELECT p.id, p.name INTO v_project_id, v_project_name\n    FROM projects p\n    JOIN project_members pm ON pm.project_id = p.id AND pm.user_id = v_user_id\n    WHERE lower(p.name) = lower(v_ios_default)\n    LIMIT 1;\n  END IF;\n\n  -- Fall back to Telegram default\n  IF v_project_id IS NULL THEN\n    SELECT p.id, p.name INTO v_project_id, v_project_name\n    FROM user_settings us\n    JOIN projects p ON lower(p.name) = lower(us.value)\n    JOIN project_members pm ON pm.project_id = p.id AND pm.user_id = v_user_id\n    WHERE us.user_id = v_user_id AND us.key = 'telegram_default_project'\n    LIMIT 1;\n  END IF;\n\n  -- Fall back to first owned project\n  IF v_project_id IS NULL THEN\n    SELECT p.id, p.name INTO v_project_id, v_project_name\n    FROM projects p\n    JOIN project_members pm ON pm.project_id = p.id\n    WHERE pm.user_id = v_user_id AND pm.role = 'owner'\n    ORDER BY p.created_at ASC\n    LIMIT 1;\n  END IF;\n\n  IF v_project_id IS NULL THEN\n    RAISE EXCEPTION 'No project found';\n  END IF;\n\n  SELECT s.id INTO v_status_id\n  FROM statuses s\n  WHERE s.project_id = v_project_id AND s.is_default = 1\n  LIMIT 1;\n\n  IF v_status_id IS NULL THEN\n    SELECT s.id INTO v_status_id\n    FROM statuses s\n    WHERE s.project_id = v_project_id\n    ORDER BY s.order_index ASC\n    LIMIT 1;\n  END IF;\n\n  SELECT COALESCE(MIN(t.order_index), 0) - 1 INTO v_order_index\n  FROM tasks t\n  WHERE t.project_id = v_project_id AND t.status_id = v_status_id\n    AND t.is_archived = 0 AND t.parent_id IS NULL;\n\n  v_task_id := gen_random_uuid();\n  INSERT INTO tasks (id, project_id, owner_id, title, status_id, priority, order_index,\n    is_template, is_archived, is_in_my_day, created_at, updated_at)\n  VALUES (v_task_id, v_project_id, v_user_id, p_title, v_status_id, 0, v_order_index,\n    0, 0, 0, v_now, v_now);\n\n  RETURN QUERY SELECT p_title, v_project_name;\nEND;\n$$ LANGUAGE plpgsql SECURITY DEFINER;"
      },
      "caller": {
        "type": "direct"
      }
    }
  ],
